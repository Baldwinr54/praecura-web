# Copiar este archivo a ".env" y ajustar los valores reales fuera del repositorio.

# PostgreSQL
POSTGRES_CONTAINER_NAME=praecura_postgres
POSTGRES_PORT=5433
POSTGRES_DB=praecura_db
POSTGRES_USER=praecurauser
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_POSTGRES

# Spring Boot
SERVER_PORT=8080
DB_HOST=localhost
DB_PORT=5433
DB_NAME=praecura_db
DB_USER=praecurauser
DB_PASSWORD=CAMBIAR_PASSWORD_DB

# Seguridad / bootstrap
PRAECURA_BOOTSTRAP_ADMIN_ENABLED=true
PRAECURA_BOOTSTRAP_ADMIN_USERNAME=admin
PRAECURA_BOOTSTRAP_ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN
PRAECURA_REMEMBER_ME_KEY=CAMBIAR_POR_LLAVE_LARGA_Y_ALEATORIA
PRAECURA_TRUST_PROXY=false
PRAECURA_DEMO_SEED=false
PRAECURA_DEMO_COUNT=50
PRAECURA_DEMO_EXIT=false
PRAECURA_BILLING_CURRENCY=DOP
