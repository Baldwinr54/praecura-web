<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!--
    Logging con correlación por request.
    RequestContextFilter coloca el X-Request-Id en MDC con la llave 'requestId'.
  -->

  <property name="CONSOLE_PATTERN"
            value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%X{requestId:-—}] %logger{36} - %msg%n"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_PATTERN}</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
